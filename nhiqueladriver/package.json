{
  "name": "nhiqueladriver",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android": "cross-env NODE_OPTIONS=\"--require ./polyfill.js\" expo run:android",
    "ios": "cross-env NODE_OPTIONS=\"--require ./polyfill.js\" expo run:ios",
    "start": "cross-env NODE_OPTIONS=\"--require ./polyfill.js\" expo start",
    "start:clear": "cross-env NODE_OPTIONS=\"--require ./polyfill.js\" expo start --clear",
    "start:win": "node -e \"const{execSync}=require('child_process');try{execSync('rmdir /s /q \\\"%TEMP%\\\\metro-cache\"',{shell:'cmd.exe',stdio:'ignore'})}catch(e){}\" && cross-env NODE_OPTIONS=\"--require ./polyfill.js\" expo start",
