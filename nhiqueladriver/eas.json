{
  "cli": {
    "version": ">= 12.4.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_ANDROID_ENABLE_16K_PAGE_SUPPORT": "true", "NODE_VERSION": "22"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_ANDROID_ENABLE_16K_PAGE_SUPPORT": "true", "NODE_VERSION": "22"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_TARGET_SDK_VERSION": "35",
        "EXPO_ANDROID_ENABLE_16K_PAGE_SUPPORT": "true",
        "NODE_VERSION": "22",
        "EXPO_PUBLIC_API_URL": "https://api.nhiquelaservicos.com/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
