{
  "expo": {
    "name": "Nhiquela Driver",
    "slug": "nhiqueladriver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/nhiquela2.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/nhiquela2.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.nhiquela.driver",
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/nhiquela2.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.nhiquela.driver",
      "supportsTablet": true,
      "usesAppleSignIn": false,
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "NSUserTrackingUsageDescription": "O Nhiquela Driver usa notificações para atualizações de pedidos e entregas."
      }
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          }
        }
      ]
    ],
    "extra": {
      "firebase": {
       "apiKey": "AIzaSyDlHUEIp6YENtHnKoizx9s1pH-FX08O5Gw",
        "authDomain": "nhiqueladriver.firebaseapp.com",
        "projectId": "nhiqueladriver",
        "storageBucket": "nhiqueladriver.firebasestorage.app",
        "messagingSenderId": "70873895337",
        "appId": "1:70873895337:web:ee31dd9615c900dd4db4b8",
        "measurementId": "G-QZ9T2YJF4C"
      },
      "eas": {
        "projectId": "5c146d00-4349-41b9-8b42-a41e24f11743"
      }
    },
    "runtimeVersion": "1.0.0"
  }
}
