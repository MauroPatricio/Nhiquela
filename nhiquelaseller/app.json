{
  "expo": {
    "name": "NhiquelaPRO",
    "slug": "nhiquelap",
    "version": "1.0.0",
    "owner": "mpatricio",
    "orientation": "portrait",
    "icon": "./assets/nhiquela3.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/nhiquela3.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "android": {
      "package": "com.mpatricio.nhiquelap",
      "versionCode": 2,
      "icon": "./assets/nhiquela3.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/nhiquela3.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK",
        "RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBCd2afNAEQpZLZzRvTKAC7t-aQQEyMxNA"
        }
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mpatricio.nhiquelap",
      "icon": "./assets/nhiquela3.png",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera to upload images.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload images.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "web": {
      "favicon": "./assets/nhiquela3.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "This app needs access to your camera to upload images."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "This app needs access to your location to find nearby delivery agents."
        }
      ],
      "expo-notifications",
      "expo-font",
      "expo-build-properties"
     
    ],
    "extra": {
      "eas": {
        "projectId": "3955dd7f-ad17-497a-966b-33dfae1b0b18"
      }
    },
    "runtimeVersion": "1.0.0"
  }
}
