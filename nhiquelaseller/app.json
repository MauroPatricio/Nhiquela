{
  "expo": {
    "name": "NhiquelaPRO",
    "slug": "nhiquelap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/nhiquela3.png",
    "userInterfaceStyle": "light",
    "splash": {
      "icon": "./assets/nhiquela3.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "ios",
      "android"
    ],
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBCd2afNAEQpZLZzRvTKAC7t-aQQEyMxNA"
        }
      },
      "icon": "./assets/nhiquela3.png",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK"
        
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/nhiquela3.png",
