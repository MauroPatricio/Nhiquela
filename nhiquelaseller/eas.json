{
  "cli": {
    "version": ">= 12.4.1",
    "appVersionSource": "remote"
  },

  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_ANDROID_ENABLE_16K_PAGE_SUPPORT": "true"
      }
    },

    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_ANDROID_ENABLE_16K_PAGE_SUPPORT": "true"
      }
    },

    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_TARGET_SDK_VERSION": "35",
        "EXPO_ANDROID_ENABLE_16K_PAGE_SUPPORT": "true"
      }
    }
  },

  "submit": {
    "production": {}
  }
}
