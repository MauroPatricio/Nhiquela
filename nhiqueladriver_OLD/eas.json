{
  "cli": {
    "version": ">= 16.20.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "experimental": {
          "enable16kPageSupport": true
        }
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "experimental": {
          "enable16kPageSupport": true
        }
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "experimental": {
          "enable16kPageSupport": true
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
