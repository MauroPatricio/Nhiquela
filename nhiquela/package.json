    "start:win": "node -e \"const{execSync}=require('child_process');try{execSync('rmdir /s /q \\\"%TEMP%\\\\metro-cache\"',{shell:'cmd.exe',stdio:'ignore'})}catch(e){}\" && node --require ./polyfill.js ./node_modules/expo/bin/cli start",
    "android": "node --require ./polyfill.js ./node_modules/expo/bin/cli run:android",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "security-check": "npm audit --audit-level=critical"
  },
