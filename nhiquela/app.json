{
  "expo": {
    "name": "nhiquela",
    "slug": "nhiquelaa",
    "scheme": "nhiquela",
    "version": "1.0.0",
    "owner": "mpatricio",
    "orientation": "portrait",
    "icon": "./assets/nhiquela2.png",
    "userInterfaceStyle": "light",

    "splash": {
      "image": "./assets/nhiquela2.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "url": "https://u.expo.dev/7467ac64-89c0-432d-ae88-f427f7c65da9"
    },
    "assetBundlePatterns": ["**/*"],
    "platforms": ["ios", "android"],

    "android": {
      "package": "com.mpatricio.nhiquelaa",
      "googleServicesFile": "./google-services.json",
      "icon": "./assets/nhiquela2.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/nhiquela2.png",
        "backgroundColor": "#ffffff"
      },

      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "INTERNET",
        "WAKE_LOCK",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "POST_NOTIFICATIONS"
      ],

      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBAy0m_iw47ZF9NcH31AGaE3lfuEhrlKlE"
        }
      }
    },

    "notification": {
      "icon": "./assets/nhiquela2.png",
      "color": "#7F00FF",
      "androidMode": "default",
      "androidCollapsedTitle": "Nhiquela",
      "androidGoogleServicesFile": "./google-services.json",
      "androidShowBadge": true
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mpatricio.nhiquelaa",
      "icon": "./assets/nhiquela2.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Nhiquela precisa acessar sua câmera para permitir o envio de imagens.",
        "NSPhotoLibraryUsageDescription": "Nhiquela precisa acessar suas fotos para enviar imagens.",
        "UIBackgroundModes": ["fetch", "remote-notification"],
        "NSUserTrackingUsageDescription": "Nhiquela usa notificações para mantê-lo atualizado sobre pedidos e entregas."
      }
    },

    "web": {
      "favicon": "./assets/nhiquela2.png"
    },

    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que Nhiquela acesse a câmera para tirar fotos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission":
            "Permita que Nhiquela acesse sua localização para encontrar entregadores próximos."
        }
      ],
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "softwareKeyboardLayoutMode": "pan",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-font"
    ],

    "extra": {
      "googleMapsApiKey": "AIzaSyBAy0m_iw47ZF9NcH31AGaE3lfuEhrlKlE",

