{
  "expo": {
    "name": "Nhiquela",
    "slug": "nhiquelaa",
    "version": "1.0.0",
    "owner": "mpatricio",
    "orientation": "portrait",
    "icon": "./assets/nhiquela2.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/nhiquela2.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mpatricio.nhiquelaa",
      "infoPlist": {
        "NSCameraUsageDescription": "Este aplicativo precisa acessar a câmera para permitir o envio de fotos.",
        "UIBackgroundModes": ["remote-notification"],
        "FirebaseAppDelegateProxyEnabled": false
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },

    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/nhiquela2.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mpatricio.nhiquelaa",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "INTERNET",
        "WAKE_LOCK",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "com.google.android.c2dm.permission.RECEIVE"
      ]
    },

    "web": {
      "favicon": "./assets/nhiquela2.png"
    },

    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que Nhiquela acesse a câmera para tirar fotos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permita que Nhiquela acesse sua localização para encontrar entregadores próximos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/nhiquela2.png",
          "color": "#E53935",
          "sounds": ["default"]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0",
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-font"
    ],

    "extra": {
      "eas": {
        "projectId": "7467ac64-89c0-432d-ae88-f427f7c65da9"
      },
      "firebase": {
        "apiKey": "AIzaSyAssq-4rWO4Ju9xg-PcNH0k3bAAkDerAY4",
        "authDomain": "nhiquela-4bfb5.firebaseapp.com",
        "projectId": "nhiquela-4bfb5",
        "storageBucket": "nhiquela-4bfb5.firebasestorage.app",
        "messagingSenderId": "127489638441",
        "appId": "1:127489638441:web:27d4f40299cb1324ca9c38",
        "measurementId": "G-FN5JGWV1S4"
      }
    },

    "runtimeVersion": "1.0.0"
  }
}
